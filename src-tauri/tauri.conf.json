{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unreal Mod Manager",
  "version": "1.0.0",
  "identifier": "com.local.unreal-mod-manager",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Unreal Mod Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "devtools": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$DOWNLOAD/**", "$APPLOCALDATA/**", "$APPCACHE/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
