{
  "name": "unreal-mod-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Local Unreal Engine mod pack manager",
  "main": "server.js",
  "scripts": {
    "build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-build.ps1",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-dev.ps1",
    "start": "node server.js",
    "test": "node --test test/*.test.js",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-dev.ps1",
    "tauri:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/tauri-build.ps1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
